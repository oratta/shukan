# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# claude
.claude/

# superset (personal worktree tool config)
.superset/

# LLM session logs
/LLM

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local
.playwright-cli/
test-results/

# longrun
/_worktrees/
openspec/config.yaml

# Tailscale cert/key (tailscale cert が cwd に書く副産物)
*.ts.net.crt
*.ts.net.key
.devserver/

# agent-loop 状態ファイル（git 管理外）
.agent-loop/
